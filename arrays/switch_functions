void Reversearray(int arr[],int size)
{
    printf("Reversearray\n");
    for(int i=0;i<size/2;i++)
    {
        int temp=arr[size-1-i];
        arr[size-1-i]=arr[i];
        arr[i]=temp;
    }
    for(int i=0;i<size;i++)
    {
        printf("%d\n",arr[i]);
    }
}



