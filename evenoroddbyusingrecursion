#include <stdio.h>

void check(int n)
{
    if(n == 0)
    {
        printf("Even");
        return;
    }

    if(n == 1)
    {
        printf("Odd");
        return;
    }

    check(n - 2);
}

int main()
{
    int n;

    scanf("%d", &n);

    if(n < 0)
        n = -n;

    check(n);

    return 0;
}
