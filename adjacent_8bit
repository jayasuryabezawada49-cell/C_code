
#include <stdio.h>
#include<stdint.h>

int main()
{
    uint8_t data;
   printf("enter the data");
   scanf("%hhu",&data);
   printf("\nprinting data\n");
   for(int i=7;i>=0;i--)
   {
       printf("%d",(data>>i)&1);
   }
  for(int i=7,j=6;j>=0;j-=2,i-=2)
   {
       if(((data>>i)&1)!=((data>>j)&1))
       {
           data^=(1<<i)|(1<<j);
          
       }
   }
   printf("\nprinting data after adjacent\n");
   for(int i=7;i>=0;i--)
   {
       printf("%d",(data>>i)&1);
   }
}
